<mxfile host="app.diagrams.net">
  <diagram name="Raspberry Pi Monitoring Architecture">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Raspberry Pi -->
        <mxCell id="pi" value="Raspberry Pi&#xa;CPU Temp (vcgencmd)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="50" y="200" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Script -->
        <mxCell id="script" value="Python Script / Telegraf&#xa;Data Collector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="260" y="200" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- Local InfluxDB -->
        <mxCell id="localdb" value="Local InfluxDB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="520" y="120" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- Cloud InfluxDB -->
        <mxCell id="clouddb" value="InfluxDB Cloud" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="520" y="300" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- Local Grafana -->
        <mxCell id="localgraf" value="Grafana (Local)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="750" y="120" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- Remote Grafana -->
        <mxCell id="remotegraf" value="Grafana (Remote)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="750" y="300" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" edge="1" parent="1" source="pi" target="script">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="script" target="localdb">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="script" target="clouddb">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="localdb" target="localgraf">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="clouddb" target="remotegraf">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>